---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Catalogo from '../components/Catalogo.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';
---

<Layout
  title="Colección Completa — Soju Creaciones"
  description="Explora toda la colección de manillas artesanales Soju Creaciones. Macramé, cuarcitos, chaquiras, cuero y más. Tejidas a mano en Cali, Colombia."
>
  <Navbar />
  <main>
    <!-- Page header -->
    <div class="bg-blanco-roto pt-28 pb-8 px-6 lg:px-12 border-b border-crema">
      <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
        <h1 class="font-playfair text-3xl lg:text-4xl text-marron font-semibold">
          Toda la Colección
        </h1>
        <a
          href="/#coleccion"
          class="flex items-center gap-1.5 font-inter text-sm text-marron/60 hover:text-marron transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Volver
        </a>
      </div>
    </div>

    <Catalogo />
  </main>
  <Footer />
  <WhatsAppButton />
</Layout>
