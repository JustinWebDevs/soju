---
// TODO: Reemplazar todas las imágenes con fotografías reales del lookbook
// Tamaños variados para efecto masonry: mezclar portrait/landscape/cuadrado
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const imagenes = [
  { src: `${base}images/galeria-1.jpg`, alt: 'Manilla de macramé usada en muñeca durante paseo al río en Colombia', ancho: 400, alto: 500 },
  { src: `${base}images/galeria-2.jpg`, alt: 'Detalle de tejido de chaquiras con colores de la bandera colombiana', ancho: 400, alto: 300 },
  { src: `${base}images/galeria-3.jpg`, alt: 'Conjunto de tres manillas artesanales combinadas en estilo boho', ancho: 400, alto: 500 },
  { src: `${base}images/galeria-4.jpg`, alt: 'Manilla de cuero vintage sobre mesa de madera con flores secas', ancho: 400, alto: 300 },
  { src: `${base}images/galeria-5.jpg`, alt: 'Manos artesanas tejiendo macramé en taller de Cali Colombia', ancho: 400, alto: 500 },
  { src: `${base}images/galeria-6.jpg`, alt: 'Pulsera de chaquiras multicolor iluminada por luz natural del sol', ancho: 400, alto: 300 },
  { src: `${base}images/galeria-7.jpg`, alt: 'Colección completa de manillas Soju Creaciones sobre papel kraft', ancho: 400, alto: 400 },
  { src: `${base}images/galeria-8.jpg`, alt: 'Manilla artesanal en destino de viaje, playa del Caribe colombiano', ancho: 400, alto: 400 },
];
---

<section class="py-20 px-6 lg:px-12 texture-lino">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div data-reveal class="text-center mb-12 flex flex-col items-center gap-3">
      <span class="font-inter text-tierra text-sm font-medium tracking-widest uppercase">Lookbook</span>
      <h2 class="font-playfair text-4xl lg:text-5xl text-marron font-semibold">
        Úsalas, compártelas,<br class="hidden sm:block" /> siéntelas
      </h2>
      <p class="font-inter text-marron/60 text-base max-w-md leading-relaxed">
        Cada foto es una historia real. Nuestras manillas viajan contigo.
      </p>
    </div>

    <!-- Grid masonry -->
    <div
      class="columns-2 md:columns-3 gap-4 space-y-4"
      id="galeria-grid"
      data-reveal
    >
      {imagenes.map((img, i) => (
        <div
          class="galeria-item break-inside-avoid cursor-pointer overflow-hidden rounded-xl group relative"
          data-src={img.src}
          data-alt={img.alt}
        >
          <!-- TODO: Reemplazar src con imagen real del lookbook -->
          <img
            src={img.src}
            alt={img.alt}
            width={img.ancho}
            height={img.alto}
            loading="lazy"
            class="w-full object-cover rounded-xl group-hover:scale-105 transition-transform duration-500"
            style={`aspect-ratio: ${img.ancho}/${img.alto}; background-color: ${['#E8DDD0','#DED5C5','#E5D8CC','#D8CFC0','#E0D5C5','#D5CCC0','#DCCFC3','#E2D6CA'][i]};`}
          />
          <!-- Overlay hover -->
          <div class="absolute inset-0 bg-marron/0 group-hover:bg-marron/20 transition-colors duration-300 rounded-xl flex items-center justify-center">
            <svg
              class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox dialog -->
<dialog class="lightbox" id="lightbox" aria-label="Imagen ampliada de la galería">
  <div class="flex flex-col items-center gap-3">
    <button
      id="lightbox-close"
      aria-label="Cerrar imagen"
      class="self-end w-9 h-9 rounded-full bg-blanco-roto text-marron flex items-center justify-center shadow-md hover:bg-crema transition-colors flex-shrink-0"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="rounded-lg shadow-2xl" />
  </div>
</dialog>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLDialogElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close')!;

  const openLightbox = (src: string, alt: string) => {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.showModal();
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    lightbox.close();
    document.body.style.overflow = '';
    lightboxImg.src = '';
  };

  document.querySelectorAll<HTMLElement>('.galeria-item').forEach((item) => {
    item.addEventListener('click', () => {
      const src = item.dataset.src!;
      const alt = item.dataset.alt!;
      openLightbox(src, alt);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.open) closeLightbox();
  });
</script>
