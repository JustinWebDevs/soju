---
// TODO: Ajustar respuestas con información real de tiempos, métodos de pago y materiales
const faqs = [
  {
    pregunta: '¿Cuánto demoran los envíos a toda Colombia?',
    respuesta: 'Los envíos a ciudades principales como Bogotá, Medellín, Barranquilla y Cali toman entre 2 y 4 días hábiles. Para municipios y zonas más apartadas puede tomar entre 4 y 7 días hábiles. Te enviamos el número de guía por WhatsApp para que puedas rastrear tu pedido en tiempo real.',
  },
  {
    pregunta: '¿Puedo personalizar los colores o el diseño de mi manilla?',
    respuesta: 'Claro que sí — ¡es parte de lo que más amamos hacer! Puedes elegir la paleta de colores, el tipo de cierre, la talla y combinar materiales. Solo cuéntanos en el chat de WhatsApp qué tienes en mente y con gusto te asesoramos. Los pedidos personalizados pueden tomar 2 a 5 días adicionales de elaboración.',
  },
  {
    pregunta: '¿Qué materiales usan en sus manillas?',
    respuesta: 'Trabajamos con hilo de algodón certificado, chaquiras de vidrio y acrílico de calidad, cuero legítimo curtido artesanalmente, cuentas de madera natural y piedras semipreciosas. Todos nuestros materiales los elegimos pensando en que tu manilla dure mucho tiempo y sea amigable con tu piel.',
  },
  {
    pregunta: '¿Cuáles son los métodos de pago disponibles?',
    respuesta: 'Aceptamos transferencias bancarias (Nequi, Daviplata, Bancolombia), pagos en efectivo contra entrega (disponible en algunas ciudades), y tarjetas débito o crédito a través de pasarelas seguras. Todo lo coordinamos por WhatsApp antes de enviarte tu pedido. ¡Nunca pedimos pagos sin confirmar primero tu dirección!',
  },
  {
    pregunta: '¿Cómo debo cuidar mi manilla para que dure más tiempo?',
    respuesta: 'Para las manillas de macramé y chaquiras, evita el contacto prolongado con agua, cremas y perfumes. Si se mojan, sécalas al aire libre. Para las de cuero, aplica una pequeña cantidad de crema para cuero cada mes. ¡Con estos cuidados básicos tu manilla te va a durar años y va a quedar aún más bonita con el uso!',
  },
];
---

<section class="py-20 px-6 lg:px-12 texture-lino">
  <div class="max-w-2xl mx-auto">

    <!-- Header -->
    <div data-reveal class="text-center mb-12 flex flex-col items-center gap-3">
      <span class="font-inter text-tierra text-sm font-medium tracking-widest uppercase">Preguntas frecuentes</span>
      <h2 class="font-playfair text-4xl lg:text-5xl text-marron font-semibold">
        Resolvemos tus dudas
      </h2>
      <p class="font-inter text-marron/60 text-base max-w-md leading-relaxed">
        ¿No encuentras lo que buscas? Escríbenos por WhatsApp, respondemos rápido.
      </p>
    </div>

    <!-- Accordion -->
    <div class="flex flex-col gap-3" id="faq-container" data-reveal>
      {faqs.map((faq, i) => (
        <div class="faq-item bg-white border border-crema rounded-2xl overflow-hidden">
          <button
            class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left"
            aria-expanded="false"
          >
            <h3 class="font-inter text-marron font-medium text-base leading-snug">
              {faq.pregunta}
            </h3>
            <svg
              class="faq-icon w-5 h-5 text-tierra flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-answer">
            <p class="font-inter text-marron/65 text-sm leading-relaxed px-6 pb-5">
              {faq.respuesta}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA WhatsApp -->
    <div data-reveal class="text-center mt-10">
      <p class="font-inter text-marron/60 text-sm mb-4">¿Tienes otra pregunta?</p>
      <a
        href="https://wa.me/573194969305?text=Hola%20Soju%20Creaciones!%20Tengo%20una%20pregunta%20%F0%9F%98%8A"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-oliva hover:text-oliva/80 font-inter font-medium text-sm border border-oliva/30 hover:border-oliva/60 px-5 py-2.5 rounded-full transition-all duration-200"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pregúntanos por WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const answer = item.querySelector<HTMLElement>('.faq-answer')!;

    trigger.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');

      // Cerrar todos los demás
      document.querySelectorAll<HTMLElement>('.faq-item').forEach((other) => {
        if (other !== item) {
          other.classList.remove('open');
          other.querySelector<HTMLButtonElement>('.faq-trigger')!.setAttribute('aria-expanded', 'false');
        }
      });

      // Toggle este
      item.classList.toggle('open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
