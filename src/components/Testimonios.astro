---
// TODO: Reemplazar con testimonios reales de clientes
const testimonios = [
  {
    nombre: 'Valentina Morales',
    ciudad: 'Medellín, Antioquia',
    avatar: 'VM',
    color: '#C4956A',
    reseña: 'Pedí la manilla de chaquiras para un regalo y llegó en un empaque tan lindo que casi no quería abrirlo. La calidad es increíble, se nota que está hecha con amor. Mi amiga lloró de la emoción. Ya pedí una para mí también 🧡',
  },
  {
    nombre: 'Camila Ruiz',
    ciudad: 'Bogotá, Cundinamarca',
    avatar: 'CR',
    color: '#7A8C5E',
    reseña: 'Las chicas de Soju son súper atentas. Me ayudaron a personalizar los colores para que fueran los de mi boda y quedaron perfectas para todas las damas. ¡Todos preguntaban dónde las habíamos conseguido!',
  },
  {
    nombre: 'Daniela Ospina',
    ciudad: 'Cali, Valle del Cauca',
    avatar: 'DO',
    color: '#3D2B1F',
    reseña: 'Llevo tres meses usando mi manilla de macramé todos los días — al baño, al gym, a dormir — y sigue perfecta. Vale cada peso. Soju Creaciones es de esas marcas que te alegran el día con cada compra.',
  },
];
---

<section class="py-20 px-6 lg:px-12 bg-marron">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div data-reveal class="text-center mb-12 flex flex-col items-center gap-3">
      <span class="font-inter text-tierra text-sm font-medium tracking-widest uppercase">Testimonios</span>
      <h2 class="font-playfair text-4xl lg:text-5xl text-blanco-roto font-semibold">
        Lo que dicen quienes<br class="hidden sm:block" /> ya las usan
      </h2>
    </div>

    <!-- Cards desktop + carrusel mobile -->
    <div class="testimonios-wrapper">
      <div class="testimonios-track" id="testimonios-track">
        {testimonios.map((t, i) => (
          <div
            class="testimonio-card flex-shrink-0 w-full md:w-auto"
            data-reveal
          >
            <div class="bg-blanco-roto/5 border border-blanco-roto/10 rounded-2xl p-7 flex flex-col gap-5 h-full">

              <!-- Estrellas -->
              <div class="flex gap-1" aria-label="5 estrellas">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4 text-tierra" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>

              <!-- Reseña -->
              <blockquote class="font-inter text-blanco-roto/80 text-sm leading-relaxed italic flex-1">
                "{t.reseña}"
              </blockquote>

              <!-- Usuario -->
              <div class="flex items-center gap-3">
                <div
                  class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 font-inter font-semibold text-blanco-roto text-sm"
                  style={`background-color: ${t.color};`}
                  aria-hidden="true"
                >
                  {t.avatar}
                </div>
                <div>
                  <p class="font-inter font-semibold text-blanco-roto text-sm">{t.nombre}</p>
                  <p class="font-inter text-blanco-roto/50 text-xs">{t.ciudad}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Dots mobile -->
    <div class="flex justify-center gap-2 mt-6 md:hidden" id="testimonios-dots" aria-hidden="true">
      {testimonios.map((_, i) => (
        <button
          class="dot w-2 h-2 rounded-full transition-all duration-200"
          data-index={i}
          style={i === 0 ? 'background-color: #C4956A; width: 24px;' : 'background-color: rgba(245,240,232,0.3);'}
          aria-label={`Ir al testimonio ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .testimonios-track {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      transform: none !important;
    }
    .testimonio-card {
      width: auto !important;
    }
  }
</style>

<script>
  const track = document.getElementById('testimonios-track')!;
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const cards = track.querySelectorAll<HTMLElement>('.testimonio-card');
  let current = 0;
  let startX = 0;

  const isMobile = () => window.innerWidth < 768;

  const goTo = (index: number) => {
    if (!isMobile()) return;
    current = index;
    track.style.transform = `translateX(-${index * 100}%)`;

    dots.forEach((dot, i) => {
      if (i === index) {
        dot.style.backgroundColor = '#C4956A';
        dot.style.width = '24px';
      } else {
        dot.style.backgroundColor = 'rgba(245,240,232,0.3)';
        dot.style.width = '8px';
      }
    });
  };

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.dataset.index!));
    });
  });

  // Touch swipe
  track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e) => {
    if (!isMobile()) return;
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0 && current < cards.length - 1) goTo(current + 1);
      else if (diff < 0 && current > 0) goTo(current - 1);
    }
  }, { passive: true });
</script>
